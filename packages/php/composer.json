{
    "name": "payment-sdk/php",
    "description": "PHP payment gateway SDK",
    "type": "library",
    "require": {
        "php": ">=8.1",
        "ext-hash": "*",
        "ext-json": "*",
        "ext-curl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "PaymentSdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PaymentSdk\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:coverage": "vendor/bin/phpunit --coverage-text"
    }
}
