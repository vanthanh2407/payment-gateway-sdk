# ============================================================
# Payment Gateway SDK Test App - Environment Variables
# Copy file này thành .env.local và điền credentials sandbox
# ============================================================

# VNPay Sandbox (https://sandbox.vnpayment.vn/apis/docs/gioi-thieu/)
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=

# MoMo Sandbox (https://developers.momo.vn/#/docs/en/aiov2/?id=payment-method)
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=

# ZaloPay Sandbox (https://docs.zalopay.vn/docs/start/)
ZALOPAY_APP_ID=
ZALOPAY_KEY1=
ZALOPAY_KEY2=

# Stripe Test (https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# VietQR Sandbox (https://developers.vietqr.org/)
VIETQR_CLIENT_ID=
VIETQR_API_KEY=
VIETQR_BANK_CODE=970010
VIETQR_BANK_ACCOUNT=
VIETQR_ACCOUNT_NAME=

# Public URL của app (dùng ngrok để expose localhost)
# Ví dụ: ngrok http 3000 → copy URL vào đây
NEXT_PUBLIC_APP_URL=http://localhost:3000
